# Supabase PostgreSQL (obtener de: Supabase > Settings > Database > Connection string)
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxxxxxxx.supabase.co:5432/postgres

# Supabase URL y Anon Key (obtener de: Supabase > Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret (puedes cambiarlo)
JWT_SECRET=smop-municipio-plaza-secret-key-2024

# Puerto del servidor
PORT=3000
